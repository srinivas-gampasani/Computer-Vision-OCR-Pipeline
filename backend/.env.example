# ============================================================
#  Computer Vision OCR Pipeline — Environment Configuration
# ============================================================

# OCR Engine
OCR_LANG=eng
PREFER_PADDLE=false
MIN_WORD_CONFIDENCE=0

# Preprocessing
DENOISE=true
DESKEW=true
BINARIZE=true
UPSCALE_FACTOR=0

# ViT layout model (optional — requires transformers + torch installed)
USE_VIT_LAYOUT=false

DEBUG=false
